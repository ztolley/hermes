# Copy this file to compose.override.yml for local experiments.
#
# docker compose automatically reads compose.override.yml, but this example file
# is ignored until copied. Keep docker-compose.yml as the stable known-good
# profile and put risky tuning here.

services:
  qwen:
    environment:
      # Larger-context experiment. Recreate qwen and hermes after changing this:
      # docker compose up -d --force-recreate qwen hermes
      MAX_MODEL_LEN: ${QWEN_MAX_MODEL_LEN:-196608}
      GPU_MEMORY_UTIL: ${QWEN_GPU_MEMORY_UTILIZATION:-0.66}

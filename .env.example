# --------------------------------------------------------------
# Example .env – copy to .env and edit with your real secrets
# --------------------------------------------------------------

# ==== Telegram ==================================================
# Get these from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USERS=123456789   # your user ID (comma‑separated if multiple)
TELEGRAM_HOME_CHANNEL=123456789    # default chat for cron delivery (optional)

# ==== Optional: other platforms =================================
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=...
# WHATSAPP_ENABLED=false

# ==== Hermes core settings ======================================
# Ports
HERMES_GATEWAY_PORT=8000
OPEN_WEBUI_PORT=3000
QWEN_PORT=9000
AUTOCOMPLETE_PORT=30001

# Hermes API server
# Open WebUI uses this to authenticate to Hermes's built-in OpenAI-compatible API.
HERMES_API_KEY=change-me-hermes-api-key

# ==== Qwen3 Coder Next / vLLM ===================================
# DGX Spark NVFP4 image and model used by the in-compose Qwen server.
QWEN_MODEL=saricles/Qwen3-Coder-Next-NVFP4-GB10
QWEN_TENSOR_PARALLEL_SIZE=1
QWEN_GPU_MEMORY_UTILIZATION=0.62
QWEN_MAX_MODEL_LEN=131072
QWEN_MAX_NUM_TOKENS=131072
QWEN_MAX_NUM_SEQS=2
QWEN_USE_FLASHINFER_MOE_FP4=0
QWEN_FLASHINFER_MOE_BACKEND=throughput
QWEN_TEST_FORCE_FP8_MARLIN=1
QWEN_NVFP4_GEMM_BACKEND=marlin

# ==== Qwen autocomplete / vLLM ==================================
# Small model endpoint intended for VS Code autocomplete.
AUTOCOMPLETE_IMAGE=vllm-node:latest
AUTOCOMPLETE_MODEL=Qwen/Qwen2.5-Coder-3B
AUTOCOMPLETE_GPU_MEMORY_UTILIZATION=0.08
AUTOCOMPLETE_MAX_MODEL_LEN=4096
AUTOCOMPLETE_TP_SIZE=1

# Required for gated Hugging Face downloads.
HF_TOKEN=your_huggingface_token_here

# ==== SSH (for Hermes terminal backend) =========================
# This project-local stack expects SSH material in ./secrets/ssh/
# and mounts that directory to /root/.ssh inside the Hermes container.
# Put id_rsa, id_rsa.pub, and known_hosts there if you want Hermes
# to execute commands on the host over SSH.
HERMES_HOST_SSH_USER=your_username
HERMES_HOST_SSH_PORT=22
HERMES_HOST_SSH_CWD=/absolute/path/to/this/repo/on/the/host

# ==== Miscellaneous ==============================================
# Example: change the logging level
# HERMES_LOG_LEVEL=INFO

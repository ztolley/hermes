# --------------------------------------------------------------
# Example .env – copy to .env and edit with your real secrets
# --------------------------------------------------------------

# ==== Telegram ==================================================
# Get these from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USERS=123456789   # your user ID (comma‑separated if multiple)
TELEGRAM_HOME_CHANNEL=123456789    # default chat for cron delivery (optional)

# ==== Optional: other platforms =================================
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=...
# WHATSAPP_ENABLED=false

# ==== Hermes core settings ======================================
# Ports
HERMES_GATEWAY_PORT=8000
OPEN_WEBUI_PORT=3000
QWEN_PORT=3001

# Hermes API server
# Open WebUI uses this to authenticate to Hermes's built-in OpenAI-compatible API.
HERMES_API_KEY=change-me-hermes-api-key

# ==== Qwen3 Coder Next / vLLM ===================================
# DGX Spark NVFP4 image and model used by the in-compose Qwen server.
QWEN_MODEL=saricles/Qwen3-Coder-Next-NVFP4-GB10
QWEN_TENSOR_PARALLEL_SIZE=1
QWEN_GPU_MEMORY_UTILIZATION=0.62
QWEN_MAX_MODEL_LEN=131072
QWEN_MAX_NUM_TOKENS=131072
QWEN_MAX_NUM_SEQS=2
QWEN_USE_FLASHINFER_MOE_FP4=0
QWEN_FLASHINFER_MOE_BACKEND=throughput
QWEN_TEST_FORCE_FP8_MARLIN=1
QWEN_NVFP4_GEMM_BACKEND=marlin
# Optional experimental vLLM speculative decoding args. Leave empty unless a
# measured, compatible draft/speculator profile is being tested.
QWEN_SPECULATIVE_ARGS=

# ==== Optional Qwen3-VL vision server ===========================
# Disabled by default. Start it with:
# docker compose --profile vision up -d qwen-vl
QWEN_VL_PORT=3003
QWEN_VL_IMAGE=avarok/dgx-vllm-nvfp4-kernel:v23
QWEN_VL_MODEL=Qwen/Qwen3-VL-8B-Instruct-FP8
QWEN_VL_TENSOR_PARALLEL_SIZE=1
QWEN_VL_GPU_MEMORY_UTILIZATION=0.16
QWEN_VL_MAX_MODEL_LEN=32768
QWEN_VL_MAX_NUM_SEQS=1
QWEN_VL_IMAGE_LIMIT=1
QWEN_VL_MM_PROCESSOR_CACHE_GB=1
QWEN_VL_EXTRA_ARGS=

# ==== Open WebUI media features =================================
# These are optional and are only read by Open WebUI on first launch or when
# its persistent config is reset/updated from the admin UI.
OPENWEBUI_ENABLE_IMAGE_GENERATION=false
OPENWEBUI_IMAGE_GENERATION_ENGINE=openai
OPENWEBUI_IMAGE_GENERATION_MODEL=gpt-image-1.5
OPENWEBUI_IMAGE_SIZE=auto
OPENWEBUI_IMAGES_OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENWEBUI_IMAGES_OPENAI_API_KEY=your_openai_api_key_here
OPENWEBUI_IMAGES_OPENAI_API_PARAMS={"quality":"medium"}

# Local Open WebUI speech-to-text uses faster-whisper. Keep this small unless
# benchmarks show enough CPU/GPU headroom for a larger model.
OPENWEBUI_WHISPER_MODEL=base
OPENWEBUI_WHISPER_VAD_FILTER=true
OPENWEBUI_WHISPER_LANGUAGE=en
OPENWEBUI_WHISPER_COMPUTE_TYPE=int8

# Required for gated Hugging Face downloads.
HF_TOKEN=your_huggingface_token_here

# ==== SSH (for Hermes terminal backend) =========================
# This project-local stack expects SSH material in ./secrets/ssh/
# and mounts that directory to /root/.ssh inside the Hermes container.
# Put id_rsa, id_rsa.pub, and known_hosts there if you want Hermes
# to execute commands on the host over SSH.
HERMES_HOST_SSH_USER=your_username
HERMES_HOST_SSH_PORT=22
HERMES_HOST_SSH_CWD=/absolute/path/to/this/repo/on/the/host

# ==== Miscellaneous ==============================================
# Example: change the logging level
# HERMES_LOG_LEVEL=INFO

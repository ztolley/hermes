# --------------------------------------------------------------
# Example .env – copy to .env and edit with your real secrets
# --------------------------------------------------------------

# ==== Telegram ==================================================
# Get these from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USERS=123456789   # your user ID (comma‑separated if multiple)
TELEGRAM_HOME_CHANNEL=123456789    # default chat for cron delivery (optional)

# ==== Optional: other platforms =================================
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=...
# WHATSAPP_ENABLED=false

# ==== Hermes core settings ======================================
# Ports
HERMES_GATEWAY_PORT=8000
OPEN_WEBUI_PORT=3000
NEMOTRON_PORT=9000

# Hermes API server
# Open WebUI uses this to authenticate to Hermes's built-in OpenAI-compatible API.
HERMES_API_KEY=change-me-hermes-api-key

# ==== Nemotron / vLLM ============================================
# Optional tuning knobs for the in-compose Nemotron server
NEMOTRON_TENSOR_PARALLEL_SIZE=1
NEMOTRON_GPU_MEMORY_UTILIZATION=0.75
NEMOTRON_MAX_MODEL_LEN=131072
NEMOTRON_MAX_NUM_SEQS=4

# ==== SSH (for Hermes terminal backend) =========================
# This project-local stack expects SSH material in ./secrets/ssh/
# and mounts that directory to /root/.ssh inside the Hermes container.
# Put id_rsa, id_rsa.pub, and known_hosts there if you want Hermes
# to execute commands on the host over SSH.
HERMES_HOST_SSH_USER=your_username
HERMES_HOST_SSH_PORT=22
HERMES_HOST_SSH_CWD=/absolute/path/to/this/repo/on/the/host

# ==== Miscellaneous ==============================================
# Example: change the logging level
# HERMES_LOG_LEVEL=INFO
